{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Default coding agent for fast, scoped execution with small diffs and lightweight verification.",
      "permission": {
        "bash": {
          "*": "allow",
          "git branch -D*": "ask",
          "git push*": "ask",
          "rm *": "ask"
        },
        "edit": "allow",
        "webfetch": "allow"
      },
      "prompt": "{file:./prompts/build.txt}"
    },
    "deepmode": {
      "description": "Autonomous coding worker for end-to-end execution, real verification, and tong-mon escalation on risky tasks.",
